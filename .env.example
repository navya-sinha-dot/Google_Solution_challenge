# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=False

# ==================== DATABASE ====================
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# For Docker Compose PostgreSQL:
DATABASE_URL=postgresql://amd_user:amd_pass@db:5432/amd_hack

# For local SQLite (development fallback):
# DATABASE_URL=sqlite:///sensor_data.db

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=True

# ==================== MQTT ====================
# In Docker, use service name 'mqtt' instead of localhost
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_KEEPALIVE=60
MQTT_RECONNECT_DELAY=5

# ==================== SENSORS ====================
STATION_ID=WS01
SENSOR_DATA_MIN_INTERVAL=8

# ==================== LLM & WORKFLOW ====================
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT=30
ENABLE_LLM_WORKFLOW=True

# ==================== TWILIO / WHATSAPP ====================
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(name)s] %(levelname)s: %(message)s

# ==================== FEATURES ====================
ENABLE_MQTT=True
ENABLE_FPGA=False
