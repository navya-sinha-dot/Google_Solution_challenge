# ============================================================
#  SkyView Smart Agriculture — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================


# ── DATABASE ────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# SSL is added automatically for neon.tech URLs.
# If not set, falls back to SQLite (fine for local dev).
DATABASE_URL=postgresql://user:password@host/dbname

# SQLite fallback path (used when DATABASE_URL is not set)
# DB_FALLBACK_SQLITE=sqlite:///sensor_data.db

# Connection pool settings (tune for production)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_PRE_PING=True
# DB_ECHO=False          # set True to log all SQL queries


# ── GROQ LLM ────────────────────────────────────────────────
# Option A: Multiple keys — load-balanced round-robin (recommended)
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Option B: Single key (used as fallback if GROQ_API_KEYS not set)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Model to use (llama-3.1-8b-instant is fast + free tier friendly)
# LLM_MODEL=llama-3.1-8b-instant
# LLM_TIMEOUT=30


# ── TWILIO / WHATSAPP ────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Phone number to receive system alerts (WhatsApp format)
# TWILIO_ALERT_RECIPIENT=whatsapp:+919876543210


# ── VAPI.AI (Voice calls) ────────────────────────────────────
# Get from https://vapi.ai/dashboard
VAPI_AI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id


# ── SARVAM AI (Text-to-speech + Translation) ─────────────────
# Get from https://www.sarvam.ai
SARVAM_AI_API_KEY=your_sarvam_api_key


# ── MANDI / GOVT DATA ────────────────────────────────────────
# Get from https://data.gov.in (free registration)
DATAGOV_API_KEY=your_datagov_api_key

# The resource ID for agmark mandi prices — default is correct, only change if API changes
# MANDI_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070


# ── MQTT (IoT sensor bridge) ─────────────────────────────────
# Your MQTT broker (local Mosquitto or cloud broker like HiveMQ)
MQTT_BROKER=localhost
# MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_KEEPALIVE=60
# MQTT_RECONNECT_DELAY=5


# ── SENSORS ──────────────────────────────────────────────────
# Default weather station ID (must match what your hardware sends)
STATION_ID=WS01

# Minimum seconds between accepted sensor readings (debounce)
# SENSOR_DATA_MIN_INTERVAL=8


# ── FPGA HARDWARE ────────────────────────────────────────────
# Set to True only when real ZC706/FPGA hardware is connected
ENABLE_FPGA=False

# Serial port for FPGA bridge (Windows: COM4, Linux: /dev/ttyUSB0)
# FPGA_PORT=COM4


# ── API SERVER ───────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=4


# ── FRONTEND / CORS ──────────────────────────────────────────
# Your frontend URL (Vite dev server or deployed URL)
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed origins for CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── FEATURE FLAGS ────────────────────────────────────────────
# ENABLE_MQTT=True
# ENABLE_LLM_WORKFLOW=True
# DEBUG=False


# ── LOGGING ──────────────────────────────────────────────────
# LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
